{
  "manifest_version": 3,
  "name": "Classic Workspace Favicons",
  "version": "0.1.0",
  "description": "Restores older, easier-to-scan favicons on Gmail, Calendar, Docs, Sheets, Slides, Drive, and other Google Workspace pages.",
  "homepage_url": "https://github.com/bmwwoo/google-old-favicons-extension",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://calendar.google.com/*",
        "https://drive.google.com/*",
        "https://docs.google.com/*",
        "https://meet.google.com/*",
        "https://chat.google.com/*",
        "https://keep.google.com/*",
        "https://tasks.google.com/*",
        "https://contacts.google.com/*",
        "https://voice.google.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/google-2020/*.svg"],
      "matches": [
        "https://mail.google.com/*",
        "https://calendar.google.com/*",
        "https://drive.google.com/*",
        "https://docs.google.com/*",
        "https://meet.google.com/*",
        "https://chat.google.com/*",
        "https://keep.google.com/*",
        "https://tasks.google.com/*",
        "https://contacts.google.com/*",
        "https://voice.google.com/*"
      ]
    }
  ]
}
